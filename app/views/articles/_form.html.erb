<%= form_with model: @article do |form|%>
    <div>
        <%= form.label :title%>
        <%= form.text_field :title%>
    </div>

    <div>
        <%= form.label :author%>
        <%= form.text_field :author%>
    </div>

    <div>
        <%= form.label :body%>
        <%= form.text_field :body%>
    </div>

    <%= form.submit%>
    <%= link_to "Cancel", articles_path%>
<%end%>